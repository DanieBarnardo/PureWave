@page "/intake"
@rendermode InteractiveServer
@inject IIntakeSubmissionStore IntakeSubmissionStore
@inject IIntakeNotificationService IntakeNotificationService
@inject ILogger<Pages.Intake> Logger

<PageTitle>PureWave | Intake Questionnaire</PageTitle>

<section class="page-intro">
    <span class="section-tag">Intake Questionnaire</span>
    <h1>Tell PureWave about your room, your gear, and what you want to enjoy more from movies and music.</h1>
    <p>
        This intake helps PureWave understand what is exciting you, frustrating you, or still missing from your current setup,
        so the first conversation starts with real context instead of generic questions.
    </p>
</section>

@if (IsSubmitted)
{
    <section class="submission-card">
        <span class="section-tag">Brief received</span>
        <h2>Thanks, @Model.FullName.</h2>
        <p>
            Your brief has been saved for review. The summary below shows the details that were captured.
        </p>

        @if (!string.IsNullOrWhiteSpace(SavedFileName))
        {
            <p><strong>Saved file:</strong> @SavedFileName</p>
        }

        <div class="submission-summary">
            <div>
                <span>Plan fit</span>
                <strong>@Model.InterestedPlan</strong>
            </div>
            <div>
                <span>Service mode</span>
                <strong>@Model.ServiceMode</strong>
            </div>
            <div>
                <span>Service format</span>
                <strong>@Model.ServiceFormat</strong>
            </div>
            <div>
                <span>Project stage</span>
                <strong>@Model.ProjectStage</strong>
            </div>
            <div>
                <span>Budget band</span>
                <strong>@Model.BudgetBand</strong>
            </div>
            <div>
                <span>Timeline</span>
                <strong>@Model.Timeline</strong>
            </div>
        </div>

        <div class="submission-notes">
            <h3>Project goals</h3>
            <p>@Model.PrimaryGoals</p>
            <h3>Known room details</h3>
            <p>@Model.RoomDimensions</p>
        </div>

        <button class="button-secondary" @onclick="StartNewSubmission">Start a new intake</button>
    </section>
}
else
{
    <EditForm Model="Model" FormName="purewave-intake" OnValidSubmit="HandleValidSubmit" class="intake-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />
        <div class="form-grid">
            <section class="form-card">
                <h2>Contact</h2>

                <label>
                    Full name
                    <InputText @bind-Value="Model.FullName" class="form-input" />
                    <ValidationMessage For="@(() => Model.FullName)" />
                </label>

                <label>
                    Email address
                    <InputText @bind-Value="Model.EmailAddress" class="form-input" />
                    <ValidationMessage For="@(() => Model.EmailAddress)" />
                </label>

                <label>
                    Phone number
                    <InputText @bind-Value="Model.PhoneNumber" class="form-input" />
                    <ValidationMessage For="@(() => Model.PhoneNumber)" />
                </label>

                <label>
                    Project suburb or area
                    <InputText @bind-Value="Model.SuburbOrArea" class="form-input" />
                    <ValidationMessage For="@(() => Model.SuburbOrArea)" />
                </label>
            </section>

            <section class="form-card">
                <h2>Project scope</h2>

                <label>
                    Service mode
                    <InputSelect Value="Model.ServiceMode" ValueChanged="@(EventCallback.Factory.Create<string>(this, OnServiceModeChanged))" ValueExpression="@(() => Model.ServiceMode)" class="form-input">
                        <option value="">Select service mode</option>
                        @foreach (var option in ServiceModeOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.ServiceMode)" />
                </label>

                <label>
                    Type of support needed
                    <InputSelect @bind-Value="Model.ServiceFormat" class="form-input">
                        <option value="">Select support format</option>
                        @foreach (var option in ServiceFormatOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.ServiceFormat)" />
                </label>

                <label>
                    Project stage
                    <InputSelect @bind-Value="Model.ProjectStage" class="form-input">
                        <option value="">Select project stage</option>
                        @foreach (var option in ProjectStageOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.ProjectStage)" />
                </label>

                <label>
                    Which plan feels closest?
                    <InputSelect @bind-Value="Model.InterestedPlan" class="form-input">
                        <option value="">Select a plan</option>
                        @foreach (var option in InterestedPlanOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.InterestedPlan)" />
                </label>

                <label>
                    Room type
                    <InputSelect @bind-Value="Model.RoomType" class="form-input">
                        <option value="">Select room type</option>
                        <option>Dedicated cinema room</option>
                        <option>Multi-purpose media room</option>
                        <option>Living room integration</option>
                        <option>New build with room not finalised</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.RoomType)" />
                </label>

                <label>
                    Budget band
                    <InputSelect @bind-Value="Model.BudgetBand" class="form-input">
                        <option value="">Select budget band</option>
                        <option>Under R20k</option>
                        <option>R20k - R50k</option>
                        <option>R50k - R100k</option>
                        <option>R100k - R250k</option>
                        <option>R250k - R500k</option>
                        <option>R500k+</option>
                        <option>Need guidance before setting budget</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.BudgetBand)" />
                </label>

                <label>
                    Target timeline
                    <InputSelect @bind-Value="Model.Timeline" class="form-input">
                        <option value="">Select timeline</option>
                        <option>Immediately</option>
                        <option>Within 1 to 3 months</option>
                        <option>Within 3 to 6 months</option>
                        <option>6 months or more</option>
                        <option>Still exploring</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.Timeline)" />
                </label>
            </section>

            <section class="form-card form-card-wide">
                <h2>Technical brief</h2>

                <label>
                    Primary goals
                    <InputTextArea @bind-Value="Model.PrimaryGoals" class="form-input form-textarea" />
                    <ValidationMessage For="@(() => Model.PrimaryGoals)" />
                </label>

                <label>
                    Room dimensions or room notes
                    <InputTextArea @bind-Value="Model.RoomDimensions" class="form-input" />
                    <ValidationMessage For="@(() => Model.RoomDimensions)" />
                </label>

                <label>
                    Existing equipment
                    <InputTextArea @bind-Value="Model.ExistingEquipment" class="form-input" />
                    <ValidationMessage For="@(() => Model.ExistingEquipment)" />
                </label>

                <label>
                    Current challenges
                    <InputTextArea @bind-Value="Model.KeyChallenges" class="form-input" />
                    <ValidationMessage For="@(() => Model.KeyChallenges)" />
                </label>
            </section>

            <section class="form-card">
                <h2>Services of interest</h2>

                @if (ShowAcousticDesign)
                {
                    <label class="check-row">
                        <InputCheckbox @bind-Value="Model.NeedsAcousticDesign" />
                        <span>@AcousticDesignLabel</span>
                    </label>
                }

                @if (ShowCalibration)
                {
                    <label class="check-row">
                        <InputCheckbox @bind-Value="Model.NeedsCalibration" />
                        <span>Calibration and DSP tuning</span>
                    </label>
                }

                @if (ShowAutomation)
                {
                    <label class="check-row">
                        <InputCheckbox @bind-Value="Model.NeedsAutomation" />
                        <span>Automation and control design</span>
                    </label>
                }

                @if (ShowProcurementAdvice)
                {
                    <label class="check-row">
                        <InputCheckbox @bind-Value="Model.NeedsProcurementAdvice" />
                        <span>Independent procurement advice</span>
                    </label>
                }

                @if (ShowExistingEquipmentInstallation)
                {
                    <label class="check-row">
                        <InputCheckbox @bind-Value="Model.NeedsExistingEquipmentInstallation" />
                        <span>Installation of existing equipment</span>
                    </label>
                }

                @if (ShowGuidanceOnly)
                {
                    <label class="check-row">
                        <InputCheckbox @bind-Value="Model.NeedsGuidanceOnly" />
                        <span>Guidance and advice only</span>
                    </label>
                }
            </section>

            <section class="form-card">
                <h2>Follow-up</h2>

                <label>
                    Preferred contact method
                    <InputSelect @bind-Value="Model.ContactPreference" class="form-input">
                        <option value="">Select contact preference</option>
                        <option>Email first</option>
                        <option>Phone call</option>
                        <option>WhatsApp</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => Model.ContactPreference)" />
                </label>

                <div class="form-tip">
                    <strong>What happens next</strong>
                    <p>Once submitted, PureWave can review the brief and guide you toward the right next step. For remote work, the process starts with WhatsApp and the consultation slot is arranged at your convenience.</p>
                </div>
            </section>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="submission-error" role="alert">@ErrorMessage</div>
        }

        <div class="form-actions">
            <button type="submit" class="button-primary" disabled="@IsSubmitting">
                @(IsSubmitting ? "Saving..." : "Submit questionnaire")
            </button>
            <a class="button-secondary" href="/plans">Review plans again</a>
        </div>
    </EditForm>
}

@code {
    private IntakeQuestionnaire Model { get; set; } = new();
    private bool IsSubmitted { get; set; }
    private bool IsSubmitting { get; set; }
    private string? ErrorMessage { get; set; }
    private string? SavedFileName { get; set; }

    private static readonly string[] ServiceModeOptions =
    [
        "On-site in Durban",
        "Remote consultancy",
        "Not sure yet"
    ];

    private static readonly string[] OnSiteProjectStageOptions =
    [
        "Planning a new room",
        "Renovating an existing room",
        "Upgrading an existing system",
        "Need tuning and calibration only"
    ];

    private static readonly string[] RemoteProjectStageOptions =
    [
        "Planning a new room",
        "Renovating an existing room",
        "Upgrading an existing system"
    ];

    private static readonly string[] AllProjectStageOptions =
    [
        "Planning a new room",
        "Renovating an existing room",
        "Upgrading an existing system",
        "Need tuning and calibration only"
    ];

    private static readonly string[] OnSitePlanOptions =
    [
        "The Blueprint",
        "The Tuning",
        "The Director"
    ];

    private static readonly string[] RemotePlanOptions =
    [
        "The Virtual Blueprint",
        "The Procurement Report"
    ];

    private static readonly string[] AllPlanOptions =
    [
        "The Blueprint",
        "The Tuning",
        "The Director",
        "The Virtual Blueprint",
        "The Procurement Report"
    ];

    private static readonly string[] OnSiteFormatOptions =
    [
        "On-site room strategy and planning",
        "On-site tuning and calibration",
        "On-site design oversight"
    ];

    private static readonly string[] RemoteFormatOptions =
    [
        "Remote layout and wiring guidance",
        "Remote procurement research",
        "Remote planning and procurement"
    ];

    private static readonly string[] AllFormatOptions =
    [
        "On-site room strategy and planning",
        "On-site tuning and calibration",
        "On-site design oversight",
        "Remote layout and wiring guidance",
        "Remote procurement research",
        "Remote planning and procurement"
    ];

    private IReadOnlyList<string> ProjectStageOptions =>
        Model.ServiceMode switch
        {
            "On-site in Durban" => OnSiteProjectStageOptions,
            "Remote consultancy" => RemoteProjectStageOptions,
            _ => AllProjectStageOptions
        };

    private IReadOnlyList<string> InterestedPlanOptions =>
        Model.ServiceMode switch
        {
            "On-site in Durban" => OnSitePlanOptions,
            "Remote consultancy" => RemotePlanOptions,
            _ => AllPlanOptions
        };

    private IReadOnlyList<string> ServiceFormatOptions =>
        Model.ServiceMode switch
        {
            "On-site in Durban" => OnSiteFormatOptions,
            "Remote consultancy" => RemoteFormatOptions,
            _ => AllFormatOptions
        };

    private bool IsRemoteMode => Model.ServiceMode == "Remote consultancy";
    private bool ShowAcousticDesign => true;
    private bool ShowCalibration => !IsRemoteMode;
    private bool ShowAutomation => !IsRemoteMode;
    private bool ShowProcurementAdvice => true;
    private bool ShowExistingEquipmentInstallation => !IsRemoteMode;
    private bool ShowGuidanceOnly => true;
    private string AcousticDesignLabel => IsRemoteMode
        ? "Remote acoustic and layout strategy"
        : "Acoustic design and treatment strategy";

    private async Task HandleValidSubmit()
    {
        try
        {
            IsSubmitting = true;
            ErrorMessage = null;
            SavedFileName = await IntakeSubmissionStore.SaveAsync(Model);
            await IntakeNotificationService.NotifyAsync(Model);
            IsSubmitted = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save PureWave intake for {EmailAddress}", Model.EmailAddress);
            ErrorMessage = "We couldn't save your brief just yet. Please try again.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void StartNewSubmission()
    {
        Model = new IntakeQuestionnaire();
        IsSubmitted = false;
        ErrorMessage = null;
        IsSubmitting = false;
        SavedFileName = null;
    }

    private void OnServiceModeChanged(string value)
    {
        Model.ServiceMode = value;

        if (!ProjectStageOptions.Contains(Model.ProjectStage))
        {
            Model.ProjectStage = string.Empty;
        }

        if (!InterestedPlanOptions.Contains(Model.InterestedPlan))
        {
            Model.InterestedPlan = string.Empty;
        }

        if (!ServiceFormatOptions.Contains(Model.ServiceFormat))
        {
            Model.ServiceFormat = string.Empty;
        }

        if (Model.ServiceMode == "Remote consultancy")
        {
            Model.NeedsCalibration = false;
            Model.NeedsAutomation = false;
            Model.NeedsExistingEquipmentInstallation = false;
        }
    }

}
